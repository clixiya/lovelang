# Never publish secrets or local config
.env
.env.*
!.env.example
.npmrc
.npmrc.*
!.npmrc.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.kdbx
*.token
*.secret
secrets.*
credentials.*

# Never publish local runtime or dev-only artifacts
vendor/
node_modules/
test/
coverage/
.nyc_output/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
*.bak
.DS_Store
.vscode/
.github/
.git/
.gitignore
